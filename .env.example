# Copy this to .env.local for local dev (never commit .env.local!)
# In production: add these in Vercel Dashboard → Settings → Environment Variables

# ── Pick ONE provider ──────────────────────────────────────────────
PROVIDER=anthropic        # Options: anthropic | openai | groq

# ── Add the matching key ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# You can store all keys and just change PROVIDER to switch backends.
